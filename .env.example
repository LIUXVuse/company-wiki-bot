# 複製此檔為 .env（本地開發用）
# 正式部署請用：wrangler secret put <KEY_NAME>

# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_BOT_TOKEN=

# LLM API Key
# NVIDIA: https://integrate.api.nvidia.com
# opencode: https://api.opencode.ai
LLM_API_KEY=

# MinerU API Token（選填）
# 留空 = 使用免費輕量版（限 10MB / 20頁）
# 需要大檔支援 → 至 https://mineru.net 申請
MINERU_API_TOKEN=
